# Copia este archivo a ".env" y completa con los datos de TU proyecto Firebase.
# El archivo ".env" real NUNCA se sube a GitHub (está en .gitignore).
# Estas variables deben empezar con VITE_ para que Vite las exponga al frontend.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Cada usuario solo puede leer/escribir su propio documento.
    // Nota: la transferencia actualiza el saldo del RECEPTOR también,
    // así que en producción esa escritura debería hacerse desde un
    // backend (Cloud Function) en vez del cliente. Para este proyecto
    // académico se deja el cliente pero documentado como deuda técnica.
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Los movimientos solo los puede leer quien participó en ellos,
    // y solo se crean (nunca se editan ni se borran).
    match /movimientos/{id} {
      allow read: if request.auth != null &&
        request.auth.uid in resource.data.participantes;
      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.participantes;
      allow update, delete: if false;
    }
  }
}
